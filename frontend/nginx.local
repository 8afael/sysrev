server {
    listen 80;
    root /usr/share/nginx/html;
    index index.html;

    # Redireciona a raiz para /sysrev/
    location = / {
        return 302 /sysrev/;
    }

    # Serve o front sob o prefixo /sysrev/
    location /sysrev/ {
        alias /usr/share/nginx/html/;
        try_files $uri $uri/ /index.html;
    }
}